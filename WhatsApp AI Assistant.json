      "position": [
        352,
        16
      ]
    },
    {
      "parameters": {
        "content": "## 💾 Conversation Logging\n\nEvery conversation is automatically saved to Google Sheets with:\n- Timestamp\n- Customer phone number\n- Original message\n- AI response\n- Message ID",
        "height": 240,
        "width": 380,
        "color": 2
      },
